    "    #         (a) 用主成分分析提取公共因子 B, f_t\n",
    "    #         (b) 估计特质协方差矩阵 Σ_ε（稀疏化处理）\n",
    "    #         (c) 合并：Σ_hat = B·Σ_f·B' + Σ_ε_hat\n",
    "    #\n",
    "    # Step 4: 代入马科维茨框架求解最优权重\n",
    "    #         （与经典方法完全一致，只是 Σ 的估计更精确）\n",
    "    # ============================================================\n",
    "\n",
    "    if 'returns' not in _portfolio_data:\n",
    "        return '错误：请先调用 download_stock_data 下载数据。'\n",
    "\n",
    "    stocks = _portfolio_data['stocks']\n",
    "\n",
    "    placeholder_result = {\n",
