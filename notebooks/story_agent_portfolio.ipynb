   "source": [
    "### 📦 第一步：导入武器库\n",
    "\n",
    "林泽远打开笔记本，开始搭建他的"量化帝国"。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "code-imports",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import json\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import yfinance as yf\n",
    "from scipy.optimize import minimize\n",
    "from dotenv import load_dotenv\n",
    "\n",
    "# LangChain 的核心组件\n",
    "from langchain_core.tools import tool           # 把普通函数变成 Agent 可以调用的「工具」\n",
    "from langchain_core.messages import HumanMessage\n",
    "from langchain_deepseek import ChatDeepSeek     # DeepSeek 大模型接口\n",
    "from langchain.agents import create_agent       # 创建 Agent 的核心函数\n",
    "\n",
    "print('✅ 武器库装备完毕。林泽远摩拳擦掌，准备大干一场。')"
   ]
